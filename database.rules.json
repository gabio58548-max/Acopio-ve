{
  "rules": {
    "centros": {
      ".read": true,

      ".indexOn": ["estado", "municipio", "capacidad", "creadoEn"],

      "$centroId": {
        ".write": true,

        ".validate": "newData.hasChildren(['nombre','estado','municipio','direccion','lat','lng','capacidad','insumos','actualizadoEn'])",

        "nombre":       { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120" },
        "estado":       { ".validate": "newData.isString() && newData.val().length > 0" },
        "municipio":    { ".validate": "newData.isString() && newData.val().length > 0" },
        "direccion":    { ".validate": "newData.isString() && newData.val().length > 0" },
        "lat":          { ".validate": "newData.isNumber() && newData.val() >= -90  && newData.val() <= 90" },
        "lng":          { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
        "capacidad":    { ".validate": "newData.val() === 'disponible' || newData.val() === 'parcial' || newData.val() === 'lleno'" },
        "insumos":      { ".validate": "newData.isString() || newData.hasChildren()" },
        "contacto":     { ".validate": "!newData.exists() || newData.isString()" },
        "responsable":  { ".validate": "!newData.exists() || newData.isString()" },
        "horario":      { ".validate": "!newData.exists() || newData.isString()" },
        "notas":        { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" },
        "creadoEn":     { ".validate": "!newData.exists() || newData.isNumber()" },
        "actualizadoEn":{ ".validate": "newData.isNumber()" },
        "verificado":   { ".validate": "!newData.exists() || newData.isBoolean()" },
        "reportes":     { ".validate": "!newData.exists() || newData.isNumber()" },

        "$other": { ".validate": false }
      }
    },

    "movimientos": {
      ".read": true,
      ".indexOn": ["centroId", "timestamp"],
      "$movId": {
        ".write": true,
        ".validate": "newData.hasChildren(['tipo','centroId','centroNombre','descripcion','persona','timestamp','operadorEmail'])",
        "tipo":          { ".validate": "newData.val() === 'entrada' || newData.val() === 'salida'" },
        "centroId":      { ".validate": "newData.isString() && newData.val().length > 0" },
        "centroNombre":  { ".validate": "newData.isString() && newData.val().length > 0" },
        "descripcion":   { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500" },
        "persona":       { ".validate": "newData.isString() && newData.val().length > 0" },
        "cedula":        { ".validate": "!newData.exists() || newData.isString()" },
        "destino":       { ".validate": "!newData.exists() || newData.isString()" },
        "placa":         { ".validate": "!newData.exists() || newData.isString()" },
        "nota":          { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 300)" },
        "operadorEmail": { ".validate": "newData.isString() && newData.val().length > 0" },
        "timestamp":     { ".validate": "newData.isNumber()" },
        "$other":        { ".validate": false }
      }
    },

    "rg_centros": {
      ".read":  true,
      ".write": true
    },

    "eventos": {
      ".read":  true,
      ".write": true
    },

    "reportes": {
      ".read":  true,
      ".write": true
    },

    "fotos_pendientes": {
      ".read":  true,
      ".write": true
    },

    "chat": {
      ".read":  true,
      ".write": true,
      "$msgId": {
        ".validate": "newData.hasChildren(['opEmail','senderLabel','texto','ts'])",
        "opEmail":      { ".validate": "newData.isString() && newData.val().length > 0" },
        "senderLabel":  { ".validate": "newData.isString() && newData.val().length > 0" },
        "texto":        { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 300" },
        "ts":           { ".validate": "newData.isNumber()" },
        "$other":       { ".validate": false }
      }
    },

    "otps": {
      "$emailKey": {
        ".read":  true,
        ".write": true,
        ".validate": "!newData.exists() || newData.hasChildren(['code','expiry'])"
      }
    },

    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
